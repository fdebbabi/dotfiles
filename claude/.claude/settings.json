{
  "permissions": {
    "deny": [
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.kube/**)",
      "Read(~/.config/argocd/**)",
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/credentials*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",

      "Bash(* | sh)",
      "Bash(* | bash)",
      "Bash(* | zsh)",

      "Bash(rm -rf /*)",
      "Bash(rm -rf ~/*)",
      "Bash(rm -rf $HOME*)",
      "Bash(git push --force *)",
      "Bash(git push -f *)"
    ],
    "allow": [
      "Bash(flutter *)",
      "Bash(dart *)",

      "Bash(ls *)",
      "Bash(ls * | head *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(file *)",
      "Bash(which *)",
      "Bash(tree *)",
      "Bash(stat *)",
      "Bash(grep *)",
      "Bash(rg *)",
      "Bash(jq *)",
      "Bash(find * -type f)",
      "Bash(find * -name *)",

      "Bash(git status)",
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git show *)",
      "Bash(git branch *)",
      "Bash(git remote *)",
      "Bash(git stash list)",

      "Bash(gh pr view *)",
      "Bash(gh pr list *)",
      "Bash(gh issue view *)",
      "Bash(gh issue list *)",
      "Bash(gh run view *)",
      "Bash(gh repo view *)",

      "Bash(brew list *)",
      "Bash(brew info *)",
      "Bash(brew search *)",
      "Bash(brew --version)",

      "Bash(stow --help)",
      "Bash(stow -n *)",

      "WebSearch",
      "WebFetch"
    ]
  },
  "preferences": {
    "codeStyle": "Do not add Co-Authored-By lines to commit messages"
  },
  "effortLevel": "xhigh",
  "statusLine": {
    "type": "command",
    "command": "echo \"${PWD##*/} | $(git branch --show-current 2>/dev/null || echo no-branch)\""
  }
}
